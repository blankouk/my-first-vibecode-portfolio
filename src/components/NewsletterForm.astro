<form
  action="#"
  method="post"
  class="rounded-xl border border-[rgba(0,240,255,0.15)] bg-[#0f0f1a] p-6 md:p-8 shadow-glow-cyan max-w-xl"
  aria-label="Weekly newsletter subscription"
>
  <div class="space-y-5">
    <div>
      <label
        for="newsletter-name"
        class="block text-sm font-medium text-[#e8e8f0] mb-2"
      >
        Full Name
      </label>
      <input
        id="newsletter-name"
        name="name"
        type="text"
        autocomplete="name"
        placeholder="[PLACEHOLDER]"
        class="w-full min-h-[44px] rounded-lg border border-[rgba(0,240,255,0.25)] bg-[#080810] px-4 text-[#e8e8f0] placeholder:text-[#7a7a9a] transition-interactive focus:border-[#00f0ff]"
      />
    </div>
    <div>
      <label
        for="newsletter-email"
        class="block text-sm font-medium text-[#e8e8f0] mb-2"
      >
        Email
      </label>
      <input
        id="newsletter-email"
        name="email"
        type="email"
        autocomplete="email"
        required
        placeholder="you@example.com"
        class="w-full min-h-[44px] rounded-lg border border-[rgba(0,240,255,0.25)] bg-[#080810] px-4 text-[#e8e8f0] placeholder:text-[#7a7a9a] transition-interactive focus:border-[#00f0ff]"
      />
    </div>
    <button
      type="submit"
      class="w-full sm:w-auto inline-flex items-center justify-center min-h-[44px] px-8 rounded-lg bg-[#00f0ff] text-[#080810] font-semibold text-sm transition-interactive hover:shadow-glow-cyan-hover"
    >
      Subscribe
    </button>
  </div>
</form>
