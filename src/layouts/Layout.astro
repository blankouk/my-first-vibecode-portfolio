---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import BackgroundDecor from "../components/BackgroundDecor.astro";
import { ClientRouter, slide } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Artem Belozertsev",
  description = "[PLACEHOLDER] Personal portfolio — finance, quant, and building.",
} = Astro.props;

const pathname = Astro.url.pathname;
---

<!doctype html>
<html lang="en" transition:name="root" transition:animate="none">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <ClientRouter />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col font-[family-name:var(--font-body)]">
    <BackgroundDecor />
    <div id="cursor-glow" aria-hidden="true"></div>
    <Navbar currentPath={pathname} />
    <main
      transition:animate={slide({ duration: "0.38s" })}
      transition:name="main"
      class="relative z-10 flex-1 w-full max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14"
    >
      <slot />
    </main>
    <Footer />
    <script is:inline>
      (function () {
        var body = document.body;
        if (!body) return;
        var reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
        var tx = 50,
          ty = 50,
          cx = 50,
          cy = 50;
        var raf = 0;
        function tick() {
          cx += (tx - cx) * 0.14;
          cy += (ty - cy) * 0.14;
          body.style.setProperty("--glow-x", cx + "%");
          body.style.setProperty("--glow-y", cy + "%");
          if (Math.abs(tx - cx) > 0.04 || Math.abs(ty - cy) > 0.04) {
            raf = requestAnimationFrame(tick);
          } else {
            raf = 0;
          }
        }
        function onMove(e) {
          if (reduce.matches) return;
          tx = (e.clientX / window.innerWidth) * 100;
          ty = (e.clientY / window.innerHeight) * 100;
          if (!raf) raf = requestAnimationFrame(tick);
        }
        window.addEventListener("mousemove", onMove, { passive: true });
        reduce.addEventListener("change", function () {
          if (reduce.matches) {
            body.style.removeProperty("--glow-x");
            body.style.removeProperty("--glow-y");
          }
        });
      })();
    </script>
    <script>
      import { initFloatingPortraits } from "../scripts/floating-portrait.ts";
      import { initBackgroundDecorParallax } from "../scripts/background-decor-parallax.ts";

      function onPageLoad() {
        initFloatingPortraits();
        initBackgroundDecorParallax();
      }

      document.addEventListener("astro:page-load", onPageLoad);
      onPageLoad();
    </script>
  </body>
</html>
